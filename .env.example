# [ IQWANENGINE SECURITY ENVIRONMENT ]
# Map these in Vercel Dashboard > Settings > Environment Variables

# Private Keys (Backend Only)
VITE_VALETAX_TOKEN="your_valetax_token_here"
VITE_APPS_SCRIPT_URL="your_google_apps_script_url_here"

# Shared Authorization (Frontend & Backend)
VITE_API_SHARED_SECRET="your_custom_secure_key_2026"

# Environment
NODE_ENV="production"
